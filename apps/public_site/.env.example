# ----------------------------------------------------------------------------
# CEXAI PUBLIC SITE (apps/public_site) -- environment.
#
# The public site is UNAUTHENTICATED: it serves a tenant's PUBLISHED catalog to
# anonymous visitors. Three knobs -- the original two + one narrow addition
# below (GO_ONLINE A2, still no login / no session anywhere on this site):
# ----------------------------------------------------------------------------

# The FastAPI backend base URL (apps/dashboard_api). The client only ever appends
# /public/tenant-info or /public/catalog to this. Server-trusted (read at build).
NEXT_PUBLIC_API_URL=http://localhost:8000

# Run the whole app on in-memory fixtures (no backend, no DB). Set to 1 for an
# offline demo / tests. When 1, NEXT_PUBLIC_API_URL is ignored.
NEXT_PUBLIC_FIXTURES=1

# === WAITLIST (GO_ONLINE A2, /intake "modo-espera") ==========================
# NOT an auth integration -- this site still has no login, no session, no JWT
# anywhere. These two vars configure ONE narrow anon-key Supabase client
# (lib/waitlist.ts) used ONLY to INSERT a row into waitlist_intake when a
# visitor joins the waitlist from /intake. The anon key is browser-safe by
# design; RLS is the real boundary (anon INSERT-only, ZERO anon SELECT -- see
# supabase/migrations/20260711000001_waitlist_intake.sql). Same var names as
# apps/dashboard_web/.env.example -- do not invent new ones.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
