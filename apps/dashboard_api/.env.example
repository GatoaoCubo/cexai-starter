# ============================================================================
# CEXAI Dashboard API (apps/dashboard_api) -- SERVER-SIDE environment.
# Copy to .env for local dev:   cp apps/dashboard_api/.env.example apps/dashboard_api/.env
# (or export these in your process manager / host secret store for prod).
#
# EVERY value here is a SERVER secret or server config. NONE of it is ever sent
# to the browser. The frontend (apps/dashboard_web) holds the NEXT_PUBLIC_* half;
# the two .env files are deliberately disjoint.
#
# .gitignore already ignores .env / .env.* and whitelists only .env.example, so a
# real filled-in .env never gets committed. Keep it that way.
#
# THE #1 RULE: tenant_id is resolved ONLY from the verified Supabase JWT
# (auth.py::extract_tenant_id). Nothing here sets or overrides a tenant.
# ============================================================================

# ----------------------------------------------------------------------------
# 1. JWT VERIFICATION  (REQUIRED to go live -- this is how the backend trusts a
#    request's tenant). HS256 with the Supabase project's JWT secret is the
#    default Supabase Auth scheme. The secret is read lazily per-request, so the
#    app still boots without it -- but every authed call then fails CLOSED (401).
# ----------------------------------------------------------------------------
# Supabase project -> Settings -> API -> JWT Settings -> "JWT Secret".
# Symmetric HS256 secret; SERVER-SIDE ONLY (never the anon key, never browser).
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Expected audience. Supabase Auth issues tokens with aud="authenticated".
# Set to "" (empty) to DISABLE the audience check (NOT recommended).
SUPABASE_JWT_AUD=authenticated

# OPTIONAL -- asymmetric verification (RS256/ES256) via the project JWKS instead
# of the shared secret. If set, this path is used and SUPABASE_JWT_SECRET is not.
# SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json

# OPTIONAL -- override the allowed signing algorithms (CSV). Defaults: HS256 for
# the secret path, RS256,ES256 for the JWKS path. Pinned to block alg-downgrade.
# SUPABASE_JWT_ALGORITHMS=HS256

# ----------------------------------------------------------------------------
# 2. CORS  (which browser Origin may call this API). Comma-separated allowlist.
#    Defaults to the local Next.js dev server. In prod set this to the deployed
#    dashboard_web origin (e.g. https://dashboard.yourbrand.com).
# ----------------------------------------------------------------------------
CEXAI_DASHBOARD_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ----------------------------------------------------------------------------
# 3. LLM CREDENTIAL for capability runs  (server-side BYO key).
#    Custody (spec B.3 / OQ5): the credential is assembled SERVER-SIDE only; the
#    browser NEVER sends one. For a single tenant per process, this DEV key is the
#    simplest path. Multi-tenant prod stores a per-tenant key on the tenant secret
#    surface (.cex/tenants/<tid>/secrets/.env) and this is the fallback only.
# ----------------------------------------------------------------------------
# A BYO provider API key used when a tenant has no stored key (local dev path).
CEXAI_DASHBOARD_DEV_API_KEY=sk-your-anthropic-or-openai-key
# Default provider for the dev credential (default: anthropic).
CEXAI_DASHBOARD_DEV_PROVIDER=anthropic
# Default model ("" -> the SDK resolves a default for the provider).
CEXAI_DASHBOARD_DEV_MODEL=

# ----------------------------------------------------------------------------
# 4. CENTRAL TENANT DATA PLANE  (the tenant_* tables: tenant_data / tenant_runtime
#    / tenant_memory, RLS-enforced per supabase/migrations/2026061600000*.sql).
#
#    These connection values are consumed by the DbSession factory YOU register
#    (see section 5 + the runbook). The backend itself does NOT open a DB
#    connection at import -- the adapter takes the session as an injected seam.
#    With NO factory registered, live reads/writes DEGRADE to empty/local-only
#    (the dashboard still runs; nothing is blocked). This is the fixtures-equivalent
#    "data plane not configured" state on the backend.
#
#    SECURITY: the factory MUST bind the verified-claim tenant onto every session
#    via set_config('request.jwt.claims', '{"tenant_id": <tid>}', is_local=True)
#    so RLS applies on pooled connections. is_local=True is MANDATORY (a false
#    value leaks tenant A's claim to the next borrower of a PgBouncer/Supavisor
#    connection -> silent cross-tenant read). The adapter already issues this bind
#    for you (adapter.bind_session_tenant); the factory just has to honor
#    set_config + execute. DO NOT register a factory that ignores set_config.
# ----------------------------------------------------------------------------
# The central Postgres/Supabase connection string the registered factory reads.
# Use the TRANSACTION-MODE pooler endpoint (PgBouncer/Supavisor) for serverless.
# Example: postgresql://USER:PASSWORD@HOST:6543/postgres?sslmode=require
CEXAI_TENANT_DB_URL=postgresql://user:password@your-project.pooler.supabase.com:6543/postgres?sslmode=require

# OPTIONAL -- service-role key, ONLY if your factory talks to Supabase via PostgREST
# instead of a raw PG connection. Most deployments use CEXAI_TENANT_DB_URL above and
# leave this unset. SERVER-SIDE ONLY; never the anon key, never the browser.
# CEXAI_TENANT_DB_KEY=your-supabase-service-role-key

# ----------------------------------------------------------------------------
# 5. DbSession FACTORY REGISTRATION  (the live-go seam).
#    The backend loads + registers your DbSession factory from this var at
#    startup. Format: "module.path:callable". The callable signature MUST be:
#        factory(tenant_id: str, user_jwt: str) -> Callable[[], DbSession]
#    i.e. it returns a ZERO-ARG factory that mints ONE fresh DbSession per call
#    (so the claim-bind and the query share one transaction). The DbSession must
#    satisfy the Protocol in cexai/governance/data/adapter.py:
#        execute(sql, params) -> driver-native result
#        set_config(key, value, is_local) -> None   (is_local=True honored!)
#
#    UNSET (default) -> no factory -> live reads/writes degrade to empty/local-only.
#    This is intentional: ship the dashboard first, wire the live driver second.
#
#    The reference driver is FOUNDER-GATED: write + validate it against STAGING
#    before prod (see _docs/compiled/runbook_dashboard_deploy.md, step (b)). Do NOT point
#    this at an unvalidated driver in production.
# ----------------------------------------------------------------------------
# CEXAI_DASHBOARD_SESSION_FACTORY=mybrand.dashboard_db:make_factory
