# ----------------------------------------------------------------------------
# CEXAI Dashboard (apps/dashboard_web) -- environment
# Copy to .env.local for local dev:  cp .env.example .env.local
# Only NEXT_PUBLIC_* vars exist here: this app is a CLIENT. No server secrets,
# no service_role key. The tenant_id is NEVER set here -- it comes from the
# Supabase session JWT (app_metadata.tenant_id).
#
# TWO MODES (one flag flips them):
#   FIXTURES  NEXT_PUBLIC_FIXTURES=1  -> no backend, no Supabase; in-memory mocks.
#   LIVE      NEXT_PUBLIC_FIXTURES=0  -> real Supabase Auth + fetch the FastAPI API.
# See _docs/compiled/runbook_dashboard_deploy.md for the full local + deploy walkthrough.
# ----------------------------------------------------------------------------

# === FIXTURES MODE (default for offline UI dev/review) ======================
# Set to 1 to run the WHOLE UI with NO backend and NO Supabase. Capabilities,
# runs, and history are served from in-memory mocks (lib/fixtures.ts) and auth is
# a local stub. Use this to develop/review the UI offline.
#   NEXT_PUBLIC_FIXTURES=1  -> mock everything (the other vars below are ignored)
#   NEXT_PUBLIC_FIXTURES=0  -> LIVE: real Supabase Auth + real backend fetch
NEXT_PUBLIC_FIXTURES=1

# === AUTH MODE (the explicit auth selector) =================================
# Which auth path the app uses. Independent of FIXTURES (that is the data-layer
# mocks flag); this picks how a SESSION is established. Going from local to the
# real gato admin is FLIPPING THIS ONE VAR + the Supabase url/anon key below.
#   NEXT_PUBLIC_CEXAI_AUTH=dev       -> local dev-login STUB: any email+password
#                                       signs in (FIXTURE_TENANT). LOCAL ONLY.
#   NEXT_PUBLIC_CEXAI_AUTH=supabase  -> REAL Supabase Auth: real logins; the JWT
#                                       app_metadata.tenant_id is the identity gate
#                                       (-> backend verify -> RLS). The DEPLOY path.
# UNSET (legacy fallback, zero-regression): FIXTURES=1 -> dev; FIXTURES=0 + the
# Supabase url/key set -> supabase. Set it explicitly for a real deploy.
#   Local default:  NEXT_PUBLIC_CEXAI_AUTH=dev   (pairs with NEXT_PUBLIC_FIXTURES=1)
#   Gato admin:     NEXT_PUBLIC_CEXAI_AUTH=supabase  (with FIXTURES=0)
NEXT_PUBLIC_CEXAI_AUTH=dev

# === LIVE MODE (required only when NEXT_PUBLIC_FIXTURES=0) ===================
# The FastAPI backend (apps/dashboard_api) base URL.
#   Local:  http://localhost:8000
#   Prod:   https://api.yourbrand.com   (the deployed dashboard_api origin)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Supabase project (PLANE 1 -- Auth). The anon key is browser-safe by design;
# RLS + the backend's JWT verification are the real boundary. Get both from:
#   Supabase project -> Settings -> API -> "Project URL" + "anon public" key.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# === OPTIONAL (both modes) ==================================================
# Brand label shown in the UI chrome. Defaults to "CEXAI".
NEXT_PUBLIC_BRAND_NAME=Sua Empresa

# Whether the management/CRUD half of the dashboard ("Data" nav) is exposed.
# Defaults ON so the mold ships its full surface. Set to 0 to hide it for a
# tenant whose overlay declares no manageable entities.
#   NEXT_PUBLIC_ENABLE_MANAGEMENT=1  -> show Data/CRUD (default)
#   NEXT_PUBLIC_ENABLE_MANAGEMENT=0  -> hide it
NEXT_PUBLIC_ENABLE_MANAGEMENT=1

# The tenant's BUSINESS SHAPE vertical -- drives the FIXTURES-mode demo vocabulary
# (lib/fixtureFlavor.ts, register R-012): a services tenant no longer previews a
# pet-retail catalog. Mirrors the backend cex_business_shape / the frozen
# apps/public_site/lib/tenantConfig.ts TenantShape.vertical value -- the distill
# step (_tools/cex_distill.py) writes this automatically from the tenant's
# detected shape; set it by hand only for local dashboard_web-only dev.
# Accepted values: "retail" selects the pet-retail demo world (demo-acme-shaped);
# "services" selects a generic IT/professional-services demo; unset or any other
# value falls through to the NEUTRAL generic-commerce demo -- never pet-specific
# as the default.
# NOTE (distill-safe formatting): keep this line the ONLY "#<KEY>=" shaped line in
# this block -- _set_env_line rewrites the FIRST line matching that shape, so an
# explanatory comment written as "# NEXT_PUBLIC_BUSINESS_SHAPE=x -> ..." would be
# rewritten INSTEAD of this template line (a real bug caught by the R-012 scratch
# emission proof).
NEXT_PUBLIC_BUSINESS_SHAPE=services
NEXT_PUBLIC_TENANT=starter
