    ".git/",
    ".claude/",
    ".cex/",
    ".github/",
    "compiled/",
    "apps/",
    "_tools/",
    "cex_sdk/",
    "cexai/",
    "brand/",
    "overlay/",
    "supabase/",
    "boot/",
    "_data/"
  ]
}